# ================================================================================
# Vercodea Auth Core - Environment Configuration Template
# ================================================================================
# Copy this file to .env and update all values for your environment
# NEVER commit your .env file with sensitive credentials to version control
# ================================================================================

# ================================================================================
# DATABASE CONFIGURATION - MySQL
# ================================================================================
# MySQL connection details for user authentication and data storage

MYSQL_HOST                    = "127.0.0.1"
MYSQL_PORT                    = 3306
MYSQL_USERNAME                = "auth_user"
MYSQL_PASSWORD                = "SecurePassword123!@#"
MYSQL_DBNAME                  = "auth_database"
MYSQL_CHARSET                 = "utf8mb4"

# Optional: Unix socket path (leave empty to use TCP connection above)
MYSQL_DIR_URL                 = ""

# ================================================================================
# REDIS CACHE CONFIGURATION
# ================================================================================
# Redis for session storage, OTP caching, and rate limiting

REDIS_HOST                    = "127.0.0.1"
REDIS_PORT                    = 6379

# Optional: Redis authentication password (leave empty if Redis has no auth)
REDIS_PASSWORD                = ""

# ================================================================================
# RATE LIMITING CONFIGURATION
# ================================================================================
# Brute force protection - controls failed login/signup attempts

MAX_ATTEMPTS                  = 5
PENALTY_PERIOD                = 60
LIMIT_EXPIRES                 = 10800

# ================================================================================
# OTP (ONE-TIME PASSWORD) CONFIGURATION
# ================================================================================
# Email-based OTP for signup verification and password recovery

OTP_EXPIRES                   = 300
OTP_VERIFICATION_ENABLED      = true

# Resend API key - get from https://resend.com
OTP_API_KEY                   = "re_YOUR_RESEND_API_KEY_HERE"
SEND_OTP_URL                  = "https://api.resend.com/emails"

# Email sender domain (must be verified on Resend)
DOMAIN                        = "noreply@yourdomain.com"

# ================================================================================
# ACCOUNT RECOVERY CONFIGURATION
# ================================================================================
# Magic link settings for password reset

ACCOUNT_RECOVERY_LIMIT_TIME   = 300
ACCOUNT_RECOVERY_SUBDOMAIN_PATH = "https://yourdomain.com/password-recovery.php"

# ================================================================================
# SESSION & COOKIE SECURITY CONFIGURATION
# ================================================================================
# Secure cookie settings for user sessions

# Session expiration (seconds): 3600 = 1 hour, 86400 = 24 hours
SESSION_EXPIRY                = 3600
SESSION_COOKIE_PATH           = "/"
SESSION_COOKIE_DOMAIN         = "yourdomain.com"
SESSION_COOKIE_SECURE         = true
SESSION_COOKIE_HTTPONLY       = true
SESSION_COOKIE_SAMESITE       = "Strict"

# ================================================================================
# SSL/TLS CONFIGURATION
# ================================================================================
# CURL SSL verification for external API calls

CURLOPT_SSL_VERIFYPEER        = true

# ================================================================================
# LOGGING CONFIGURATION
# ================================================================================
# Application logs location and environment mode

LOG_DIR                       = "./logs"
APP_ENV                       = "development"   # development or production